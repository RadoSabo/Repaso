{
  "cli": {
    "version": ">= 12.0.0",
    "appVersionSource": "local"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal"
    },
    "preview": {
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      },
      "env": {
        "EXPO_PUBLIC_PROXY_URL": "https://repaso.expo.app",
        "EXPO_PUBLIC_REVENUECAT_KEY_IOS": "appl_REPLACE",
        "EXPO_PUBLIC_REVENUECAT_KEY_ANDROID": "goog_REPLACE"
      }
    },
    "production": {
      "autoIncrement": true,
      "android": {
        "buildType": "app-bundle"
      },
      "env": {
        "EXPO_PUBLIC_PROXY_URL": "https://repaso.expo.app",
        "EXPO_PUBLIC_REVENUECAT_KEY_IOS": "appl_REPLACE",
        "EXPO_PUBLIC_REVENUECAT_KEY_ANDROID": "goog_REPLACE"
      }
    }
  },
  "submit": {
    "production": {}
  }
}
