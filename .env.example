# Server-side env for the card-generation proxy (src/app/api/generate+api.ts).
# Copy to .env (gitignored) for local dev, and set as secrets on EAS Hosting.

# Required: your OpenAI secret key. NEVER ship this in the mobile app.
OPENAI_API_KEY=sk-...

# Optional: model to use (defaults to gpt-4o-mini).
OPENAI_MODEL=gpt-4o-mini

# Optional: shared bearer token the app must send (set the same value in the
# app's Settings > App token). Leave unset to allow unauthenticated access.
APP_TOKEN=

# --- App (client) build var --------------------------------------------------
# The app calls one fixed backend, hardcoded in src/lib/config.ts. This var only
# OVERRIDES that default at build time (e.g. set in eas.json build.<profile>.env)
# if you deploy the proxy to a different host. Not a secret; not user-editable.
EXPO_PUBLIC_PROXY_URL=
