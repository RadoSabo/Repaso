# Server-side env for the card-generation proxy (src/app/api/generate+api.ts).
# Copy to .env (gitignored) for local dev, and set as secrets on EAS Hosting.

# Required: your OpenAI secret key. NEVER ship this in the mobile app.
OPENAI_API_KEY=sk-...

# Optional: model to use (defaults to gpt-4o-mini).
OPENAI_MODEL=gpt-4o-mini

# --- App (client) build var --------------------------------------------------
# The app calls one fixed backend, hardcoded in src/lib/config.ts. This var only
# OVERRIDES that default at build time (e.g. set in eas.json build.<profile>.env)
# if you deploy the proxy to a different host. Not a secret; not user-editable.
EXPO_PUBLIC_PROXY_URL=

# --- RevenueCat public SDK keys (client) -------------------------------------
# Public SDK keys — safe to ship in the app. Read in src/lib/revenuecat.ts.
# Dev: a single RevenueCat Test Store key (starts with `test_`) works for BOTH
# platforms and routes purchases to the Test Store (no App Store / Play products
# needed). Set it here for local dev.
EXPO_PUBLIC_REVENUECAT_KEY=test_...
# Release builds CRASH on a Test Store key — set the real platform keys in
# eas.json for preview/production instead (iOS `appl_…`, Android `goog_…`).
EXPO_PUBLIC_REVENUECAT_KEY_IOS=
EXPO_PUBLIC_REVENUECAT_KEY_ANDROID=

# --- RevenueCat secret key (server only) -------------------------------------
# Secret REST key (starts with `sk_`). Server-side ONLY — never EXPO_PUBLIC,
# never in the app bundle. Set as an EAS Hosting secret. Used by requirePro() to
# gate the Pro-only voice/image routes and unlimited generation. The gate fails
# CLOSED: without this key (or without an active entitlement) Pro is denied in
# EVERY environment — voice/image and unlimited generation will not work.
REVENUECAT_SECRET_KEY=

# --- Upstash Redis (server only) — free-generation quota counter -------------
# REQUIRED. Holds the per-device free-generation count with a 30-day TTL.
# Server-side ONLY. The generate route fails CLOSED without it (HTTP 500): the
# free limit cannot be enforced, so generation is refused rather than served
# ungated. Set both for local dev (free Upstash tier) and as EAS Hosting secrets.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
